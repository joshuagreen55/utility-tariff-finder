DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/utility_tariff_finder
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/utility_tariff_finder
REDIS_URL=redis://localhost:6379/0
OPENEI_API_KEY=your_openei_api_key_here
GEOCODER_PROVIDER=census
GOOGLE_MAPS_API_KEY=
# Comma-separated; add your production UI origin when deploying (e.g. https://tariffs.example.com)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Production: set a long random string. Admin UI / agents send X-Admin-Key: <value>
# Leave empty for local dev (admin routes open).
ADMIN_API_KEY=
