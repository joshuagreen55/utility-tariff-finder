# Get a free API key from https://console.cloud.google.com/apis/credentials
# Enable "Places API" and "Maps JavaScript API" on the key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Must match backend ADMIN_API_KEY when that is set (Monitoring admin pages)
# Leave empty if backend ADMIN_API_KEY is empty (local dev)
VITE_ADMIN_API_KEY=
