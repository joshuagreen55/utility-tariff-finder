# Copy to repo root as `.env` for docker compose
#
# DATABASE_URL must use Docker service hostname `db` (not localhost).

# Required — set a strong password for both Postgres and Redis
POSTGRES_PASSWORD=change-me-to-a-strong-password
REDIS_PASSWORD=change-me-to-a-strong-password

# These use POSTGRES_PASSWORD automatically via docker-compose.yml defaults.
# Only override if you need a custom connection string.
# DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@db:5432/utility_tariff_finder
# SYNC_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/utility_tariff_finder
# REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

OPENEI_API_KEY=
GEOCODER_PROVIDER=census
GOOGLE_MAPS_API_KEY=

# Browser origins allowed to call the API (add your https:// domain)
CORS_ORIGINS=http://localhost,http://127.0.0.1

# --- Optional: Google sign-in (@getmysa.com only) ---
# Set AUTH_ENABLED=true and create an OAuth "Web client" in Google Cloud Console.
# OAuth cannot use a bare VM IP in Google Console — use a hostname (e.g. https://app.getmysa.com or http://YOUR_IP.nip.io).
# Ready nip.io template for VM 34.63.25.32: deploy/oauth-nipio.env.snippet (merge into this file on the server).
# Authorized redirect URI must match exactly, e.g. https://app.getmysa.com/api/auth/google/callback
# AUTH_ENABLED=true
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# AUTH_GOOGLE_REDIRECT_URI=http://YOUR_HOST/api/auth/google/callback
# PUBLIC_APP_URL=http://YOUR_HOST
# AUTH_SESSION_SECRET=change-me-to-a-long-random-string
# AUTH_ALLOWED_EMAIL_DOMAIN=getmysa.com
# AUTH_COOKIE_SECURE=false
# Use AUTH_COOKIE_SECURE=true when serving https:// only

# Required on public VMs — use the same value as VITE_ADMIN_API_KEY when building the web image
ADMIN_API_KEY=

# Passed as Docker build-args for the React production bundle (optional if admin UI not used)
VITE_GOOGLE_MAPS_API_KEY=
VITE_ADMIN_API_KEY=

# Optional: map host port 8080 -> Caddy 80 if 80 is busy
# HTTP_PORT=8080
